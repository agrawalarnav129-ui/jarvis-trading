# ════════════════════════════════════════════════════════════════
# JARVIS / AXIOM — environment template
# Copy to ".env" and fill in. NEVER commit the real .env.
# In GitHub Actions, add each of these as a repository Secret instead.
# ════════════════════════════════════════════════════════════════

# ── AI (Groq, free at console.groq.com) ──
GROQ_API_KEY=



# ── Telegram alerts (briefings + PDFs are delivered here) ──
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── YouTube Data API v3 (optional) — reliable Live-TV auto-pick from the cloud.
#    Free key: console.cloud.google.com → enable "YouTube Data API v3" → API key.
#    Without it, the Live-TV card still works (manual switch / best-effort scrape).
YOUTUBE_API_KEY=

# ── Misc ──
TZ=Asia/Kolkata
